# Este es un fichier example. NO USAR EN PRODUCCIÓN SIN MODIFICAR.
# Para usarlo, renómbrelo a "docker-compose.yml" y reemplace los valores
# sensibles (passwords, usuarios, etc.) por los valores deseados.

services:
  # ==========================================
  # DATABASES
  # ==========================================
  auth-db:
    image: mysql:8.0
    container_name: auth-db
    restart: always
    environment:
      MYSQL_DATABASE: auth_db
      MYSQL_USER: TU_AUTH_USER
      MYSQL_PASSWORD: TU_AUTH_PASSWORD
      MYSQL_ROOT_PASSWORD: TU_ROOT_PASSWORD
    ports:
      - "3307:3306"
    volumes:
      - auth_mysql_data:/var/lib/mysql
    command: --default-authentication-plugin=mysql_native_password
    networks:
      - playground-net
    healthcheck:
      test: ["CMD", "mysqladmin" ,"ping", "-h", "localhost"]
      timeout: 20s
      retries: 10

  property-db:
    image: postgres:15-alpine
    container_name: property-db
    restart: always
    environment:
      POSTGRES_DB: property_db
      POSTGRES_USER: TU_PROPERTY_USER
      POSTGRES_PASSWORD: TU_PROPERTY_PASSWORD
    ports:
      - "5432:5432"
    volumes:
      - property_pg_data:/var/lib/postgresql/data
    networks:
      - playground-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U property_user -d property_db"]
      interval: 10s
      timeout: 5s
      retries: 5

  lead-db:
    image: postgres:15-alpine
    container_name: lead-db
    restart: always
    environment:
      POSTGRES_DB: lead_db
      POSTGRES_USER: TU_LEAD_USER
      POSTGRES_PASSWORD: TU_LEAD_PASSWORD
    ports:
      - "5433:5432"
    volumes:
      - lead_pg_data:/var/lib/postgresql/data
    networks:
      - playground-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U lead_user -d lead_db"]
      interval: 10s
      timeout: 5s
      retries: 5

  fsbo-db:
    image: postgres:15-alpine
    container_name: fsbo-db
    restart: always
    environment:
      POSTGRES_DB: fsbo_db
      POSTGRES_USER: TU_FSBO_USER
      POSTGRES_PASSWORD: TU_FSBO_PASSWORD
    ports:
      - "5434:5432"
    volumes:
      - fsbo_pg_data:/var/lib/postgresql/data
    networks:
      - playground-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U fsbo_user -d fsbo_db"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ==========================================
  # KAFKA INFRASTRUCTURE
  # ==========================================
  zookeeper:
    image: confluentinc/cp-zookeeper:7.4.0
    container_name: zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000
    networks:
      - playground-net
    healthcheck:
      test: ["CMD", "echo", "ruok", "|", "nc", "localhost", "2181", "|", "grep", "imok"]
      interval: 10s
      timeout: 5s
      retries: 5

  broker:
    image: confluentinc/cp-kafka:7.4.0
    container_name: broker
    depends_on:
      zookeeper:
        condition: service_healthy
    ports:
      - "9092:9092"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: 'zookeeper:2181'
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_LISTENERS: PLAINTEXT://0.0.0.0:29092,PLAINTEXT_HOST://0.0.0.0:9092
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://broker:29092,PLAINTEXT_HOST://localhost:9092
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 1
    networks:
      - playground-net
    healthcheck:
      test: ["CMD", "kafka-topics", "--bootstrap-server", "broker:29092", "--list"]
      interval: 30s
      timeout: 10s
      retries: 5

  # ==========================================
  # CORE SERVICES
  # ==========================================
  service-registry:
    build:
      context: .
      dockerfile: service-registry/Dockerfile
    container_name: service-registry
    profiles: ["dev"]
    ports:
      - "8761:8761"
    environment:
      - SPRING_APPLICATION_JSON={"eureka":{"client":{"registerWithEureka":false,"fetchRegistry":false},"instance":{"hostname":"service-registry"}}}
    networks:
      - playground-net
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8761/actuator/health"]
      interval: 10s
      timeout: 5s
      retries: 10

  config-service:
    build:
      context: .
      dockerfile: config-service/Dockerfile
    container_name: config-service
    profiles: ["dev"]
    ports:
      - "8888:8888"
    environment:
      - SPRING_APPLICATION_JSON={"eureka":{"client":{"serviceUrl":{"defaultZone":"http://service-registry:8761/eureka/"}}}}
      - SPRING_PROFILES_ACTIVE=native
    networks:
      - playground-net
    depends_on:
      service-registry:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8888/actuator/health"]
      interval: 10s
      timeout: 5s
      retries: 10

  # ==========================================
  # BUSINESS MICROSERVICES
  # ==========================================
  auth-service:
    build:
      context: .
      dockerfile: auth-service/Dockerfile
    container_name: auth-service
    profiles: ["dev"]
    ports:
      - "8082:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - SPRING_APPLICATION_JSON={"eureka":{"client":{"serviceUrl":{"defaultZone":"http://service-registry:8761/eureka/"}}}}
      - SPRING_CONFIG_IMPORT=optional:configserver:http://config-service:8888/
    depends_on:
      auth-db:
        condition: service_healthy
      service-registry:
        condition: service_healthy
      config-service:
        condition: service_healthy
    networks:
      - playground-net

  property-service:
    build:
      context: .
      dockerfile: property-service/Dockerfile
    container_name: property-service
    profiles: ["dev"]
    ports:
      - "8081:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - SPRING_APPLICATION_JSON={"eureka":{"client":{"serviceUrl":{"defaultZone":"http://service-registry:8761/eureka/"}}}}
      - SPRING_CONFIG_IMPORT=optional:configserver:http://config-service:8888/
    depends_on:
      property-db:
        condition: service_healthy
      broker:
        condition: service_healthy
      service-registry:
        condition: service_healthy
      config-service:
        condition: service_healthy
    networks:
      - playground-net

  lead-service:
    build:
      context: .
      dockerfile: lead-service/Dockerfile
    container_name: lead-service
    profiles: ["dev"]
    ports:
      - "8083:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - SPRING_CONFIG_IMPORT=optional:configserver:http://config-service:8888/
      - EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://service-registry:8761/eureka/
    depends_on:
      lead-db:
        condition: service_healthy
      broker:
        condition: service_healthy
      service-registry:
        condition: service_healthy
      config-service:
        condition: service_healthy
    networks:
      - playground-net

  fsbo-ingestor-service:
    build:
      context: .
      dockerfile: fsbo-ingestor-service/Dockerfile
    container_name: fsbo-ingestor-service
    profiles: ["dev"]
    ports:
      - "8084:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - SPRING_CONFIG_IMPORT=optional:configserver:http://config-service:8888/
      - EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://service-registry:8761/eureka/
    depends_on:
      fsbo-db:
        condition: service_healthy
      broker:
        condition: service_healthy
      service-registry:
        condition: service_healthy
      config-service:
        condition: service_healthy
    networks:
      - playground-net

  # ==========================================
  # API GATEWAY
  # ==========================================
  api-gateway:
    build:
      context: .
      dockerfile: api-gateway/Dockerfile
    container_name: api-gateway
    profiles: ["dev"]
    ports:
      - "8080:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - SPRING_APPLICATION_JSON={"eureka":{"client":{"serviceUrl":{"defaultZone":"http://service-registry:8761/eureka/"}}}}
      - SPRING_CONFIG_IMPORT=optional:configserver:http://config-service:8888/
    depends_on:
      service-registry:
        condition: service_healthy
      config-service:
        condition: service_healthy
      auth-service:
        condition: service_started
      property-service:
        condition: service_started
      lead-service:
        condition: service_started
      fsbo-ingestor-service:
        condition: service_started
    networks:
      - playground-net

networks:
  playground-net:
    driver: bridge

volumes:
  auth_mysql_data:
  property_pg_data:
  lead_pg_data:
  fsbo_pg_data: